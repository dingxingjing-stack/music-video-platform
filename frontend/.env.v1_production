# V1.1 前端环境配置 - 公测版
# 日期：2026-07-14
# 用途：配置 API 基地址 + 功能开关

# ===== API 地址 =====
# 生产环境：Cloud Run / Railway 部署地址
VITE_API_BASE_URL=https://music-api-xxx.run.app
# 本地测试：http://localhost:8001
# VITE_API_BASE_URL=http://localhost:8001

# ===== 功能开关 =====
# 公测期关闭的功能 (二期开放)
VITE_ENABLE_VOICE_CLONE=false
VITE_ENABLE_MV_GENERATION=false
VITE_ENABLE_PAYMENT=false
VITE_ENABLE_COMMUNITY=false
VITE_ENABLE_COLLABORATION=false
VITE_ENABLE_AW_EDIT=false

# 公测期开放的功能
VITE_ENABLE_AI_GENERATION=true
VITE_ENABLE_MUSIC_GEN=true
VITE_ENABLE_DAW_BASIC=true
VITE_ENABLE_SHARE=true
VITE_ENABLE_LIBRARY=true

# ===== 第三方服务 =====
# Sentry 监控 (可选)
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=production

# ===== AI 服务配置 =====
# Gemini API (前端直连，用于歌词生成)
VITE_GEMINI_API_KEY=your_gemini_key
VITE_GEMINI_MODEL=gemini-2.0-flash

# ===== 业务配置 =====
# 每日生成配额
VITE_MAX_DAILY_GENERATIONS=10
# 单次生成最大时长 (秒)
VITE_MAX_DURATION=120
# 支持的文件格式
VITE_SUPPORTED_AUDIO_formats=mp3,wav,flac

# ===== UI 配置 =====
VITE_APP_NAME="Music Video Platform"
VITE_APP_VERSION=1.1.0
VITE_APP_ENV=production