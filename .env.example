# Env file for docker-compose
# Copy to .env and fill in real values

WORKFLOW_MODE=mock
TTS_BACKEND_MODE=mock

# HF Spaces URLs (leave empty to use mock)
MUSICGEN_SPACE_URL=
TTS_SPACE_URL=
DEMUCS_SPACE_URL=

# API tokens (leave empty to use mock)
MUSICGEN_TOKEN=
TTS_TOKEN=
DEMUCS_TOKEN=

# LLM APIs
NVIDIA_LLM_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# MIDI SoundFont path (optional, default is FluidR3_GM.sf2)
MIDI_SOUNDFONT_PATH=/usr/share/sounds/sf2/FluidR3_GM.sf2
