# ============================================================================
# HuggingFace Space 地址配置
# ============================================================================
# 格式: https://用户名-or-组织名/空间名.hf.space
# 如果是私有 Space，请取消注释并填入对应的 API Token

# TTS (语音合成)
# NOTE: sec-ai/GPT-SoVITS returns 404 (space taken down/made private).
# To use real TTS, uncomment and set a working GPT-SoVITS space:
# GPT_SOVITS_SPACE_URL=https://huggingface.co/spaces/OWNER/GPT-SoVITS-Space
# GPT_SOVITS_API_TOKEN=hf_xxxxxxxxxxxxxxxx
GPT_SOVITS_SPACE_URL=https://huggingface.co/spaces/sec-ai/GPT-SoVITS

# TTS backend mode: "mock" (default, simulated) or "real" (GPT-SoVITS HF Space)
TTS_BACKEND_MODE=mock

# Workflow mode: "mock" (default, simulated) or "real" (uses HF Spaces)
WORKFLOW_MODE=mock

# Demucs (音频分轨 / stem separation)
# DEMUCS_SPACE_URL=https://huggingface.co/spaces/OWNER/Demucs-Space
# DEMUCS_API_TOKEN=hf_xxxxxxxxxxxxxxxx
# DEMUCS_FN_INDEX=0
# DEMUCS_HTTP_TIMEOUT=600

# MusicGen (音乐生成)
MUSICGEN_SPACE_URL=https://huggingface.co/spaces/facebook/MusicGen
# MUSICGEN_API_TOKEN=hf_xxxxxxxxxxxxxxxx
# MUSICGEN_HTTP_TIMEOUT=30
# MUSICGEN_FN_INDEX=0

# CogVideoX (视频生成)
COGVIDEOX_SPACE_URL=https://huggingface.co/spaces/THUDM/CogVideoX-Demo
# COGVIDEOX_API_TOKEN=hf_xxxxxxxxxxxxxxxx
# COGVIDEOX_HTTP_TIMEOUT=60
# COGVIDEOX_FN_INDEX=0
