# ─── 数据库配置 ───────────────────────────────────────

# PostgreSQL (生产环境)
DATABASE_URL=postgresql://hermes:hermes_password@localhost:5432/hermes_platform
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_password
POSTGRES_DB=hermes_platform

# 连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# CDN 配置 (Cloudflare R2)
CDN_BASE_URL=https://cdn.hermes-platform.com
CDN_BUCKET=hermes-audio-platform
CLOUDFLARE_R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
CLOUDFLARE_R2_ACCESS_KEY=YOUR_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_KEY=YOUR_R2_SECRET_KEY

# ─── 现有配置 ───────────────────────────────────────

# Gemini API 密钥
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Mureka API 密钥
MUREKA_API_KEY=op_pw90w7tcbmf2at4afz9crzd1lvzvzghzb

# RunwayML API 密钥 (P3-2 AI 特效)
RUNWAYML_API_KEY=YOUR_RUNWAYML_API_KEY

# 服务器配置
HOST=0.0.0.0
PORT=8001

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# TTS 后端模式
TTS_BACKEND_MODE=mock
WORKFLOW_MODE=mock

# 隐私模式
PRIVACY_MODE=false

# ─── 其他服务 ───────────────────────────────────────

# Creatomate API (MV 生成)
CREATOMATE_API_KEY=YOUR_CREATOMATE_KEY
CREATOMATE_TEMPLATE_ID=ad45bcc0-11c0-4a85-bd00-27f74bde332e

# NVIDIA NVAPI (可选)
NVAPI_KEY=YOUR_NVAPI_KEY

# 文件上传限制
MAX_UPLOAD_SIZE_MB=100

# 日志级别
LOG_LEVEL=INFO